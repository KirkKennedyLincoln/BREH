# Copy to .env and fill in. .env is gitignored.

# Required: Anthropic API key used by both BREH and the smolagent baseline.
ANTHROPIC_API_KEY=sk-ant-...

# Required for container dispatch: tells the executor where the runner gRPC
# server lives. Without this, the executor runs every step inline regardless
# of weight. `task up` starts the runner on this address.
RUNNER_ADDR=localhost:50055

# Optional. Defaults to localhost:50054 if unset; only override if you've
# moved the storage server.
# STORAGE_ADDR=localhost:50054
